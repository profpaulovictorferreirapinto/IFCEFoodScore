
{
  "entities": {
    "Rating": {
      "title": "Rating",
      "description": "Individual student feedback on daily meals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "score": { "type": "number" },
        "ratingDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "score", "ratingDate", "createdAt"]
    },
    "DailySummary": {
      "title": "DailySummary",
      "description": "Pre-computed daily statistics.",
      "type": "object",
      "properties": {
        "averageScore": { "type": "number" },
        "totalRatings": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "AdminRole": {
      "title": "AdminRole",
      "description": "Database-backed access control for administrators.",
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/ratings/{ratingId}": {
      "schema": { "$ref": "#/backend/entities/Rating" },
      "description": "Stores individual anonymous ratings."
    },
    "/daily_summaries/{date}": {
      "schema": { "$ref": "#/backend/entities/DailySummary" },
      "description": "Aggregated daily data for the admin dashboard."
    },
    "/roles_admin/{userId}": {
      "schema": { "$ref": "#/backend/entities/AdminRole" },
      "description": "Identifies admin users."
    }
  }
}
