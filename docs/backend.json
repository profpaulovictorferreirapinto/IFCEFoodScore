{
  "entities": {
    "DailyMealRating": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DailyMealRating",
      "type": "object",
      "description": "Represents a single rating given by a student for the meal or snack of a specific day.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the rating."
        },
        "ratingDate": {
          "type": "string",
          "description": "The specific date (YYYY-MM-DD).",
          "format": "date"
        },
        "ratingValue": {
          "type": "number",
          "description": "Numerical rating from 1 to 5."
        },
        "period": {
          "type": "string",
          "description": "The meal period (Lanche Manhã, Almoço, Lanche Tarde, Lanche Noite).",
          "enum": ["Lanche Manhã", "Almoço", "Lanche Tarde", "Lanche Noite"]
        },
        "campus": {
          "type": "string",
          "description": "The campus name where the rating was made."
        },
        "createdAt": {
          "type": "string",
          "description": "Full timestamp of the rating.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "ratingDate",
        "ratingValue",
        "period",
        "createdAt"
      ]
    },
    "MealFeedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MealFeedback",
      "type": "object",
      "description": "Captures written suggestions or complaints from students.",
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "description": "The message content."
        },
        "ratingDate": {
          "type": "string",
          "format": "date"
        },
        "campus": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "content",
        "ratingDate",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/dailyMealRatings/{ratingId}",
        "definition": {
          "entityName": "DailyMealRating",
          "schema": {
            "$ref": "#/backend/entities/DailyMealRating"
          },
          "description": "Collection for anonymous meal ratings."
        }
      },
      {
        "path": "/mealFeedbacks/{feedbackId}",
        "definition": {
          "entityName": "MealFeedback",
          "schema": {
            "$ref": "#/backend/entities/MealFeedback"
          },
          "description": "Collection for written student feedback (suggestions/complaints)."
        }
      },
      {
        "path": "/roles_admin/{adminUid}",
        "definition": {
          "entityName": "admin",
          "schema": {
            "$ref": "#/backend/entities/user"
          },
          "description": "Admin roles management."
        }
      }
    ]
  }
}
